{
  "name": "hk-ipo-monitor",
  "version": "0.1.0",
  "private": true,
  "description": "Local HK IPO monitoring dashboard with snapshot history and optional Telegram alerts.",
  "scripts": {
    "start": "node server.js",
    "test": "node --test",
    "refresh": "node -e \"require('./src/snapshot-service').refreshOnce().then((result) => { console.log(JSON.stringify(result.summary, null, 2)); }).catch((err) => { console.error(err); process.exit(1); })\""
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
